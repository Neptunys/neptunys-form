{
  "name": "neptunys-quizz",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy:guard:blueprint": "node ./scripts/verify-render-blueprint.mjs --file ./render.yaml --expected-homepage https://form.neptunysengine.com --expected-cookie-domain form.neptunysengine.com",
    "deploy:guard:live": "node ./scripts/verify-render-live.mjs --base-url https://form.neptunysengine.com --expected-domain form.neptunysengine.com",
    "deploy:guard": "npm run deploy:guard:blueprint && npm run deploy:guard:live",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "supabase": "^2.84.6",
    "typescript": "^5.8.3",
    "vite": "^6.2.6"
  }
}
